# 3. Run: GOOGLE_CLIENT_ID=... GOOGLE_CLIENT_SECRET=... python scripts/gmail_auth.py
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER=your-address@gmail.com

